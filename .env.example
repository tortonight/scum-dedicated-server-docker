# ============================================
# SCUM Dedicated Server - Environment Variables
# ============================================
# ตั้งค่าก่อนเริ่ม Container
# Copy เป็น .env: cp .env.example .env
# ============================================

# พอร์ตของเกม (ค่าเริ่มต้น: 7777)
GAMEPORT=7777

# พอร์ตสำหรับ Server Query (ค่าเริ่มต้น: 27015)
QUERYPORT=27015

# จำนวนผู้เล่นสูงสุด (ค่าเริ่มต้น: 64)
MAXPLAYERS=64

# แฟล็กเพิ่มเติมสำหรับเซิร์ฟเวอร์ (เว้นว่างได้)
ADDITIONALFLAGS=

# เปิด/ปิด การอัปเดตอัตโนมัติเมื่อเริ่ม Container (true/false)
GAME_UPDATE=false

# เกณฑ์การใช้ Memory (%) ที่จะรีสตาร์ทเซิร์ฟเวอร์อัตโนมัติ (ค่าเริ่มต้น: 95)
MEMORY_THRESHOLD_PERCENT=95

# ระยะเวลากວດสอบ Memory (วินาที) (ค่าเริ่มต้น: 60)
MEMORY_CHECK_INTERVAL=60

# เวลารีสตาร์ทเซิร์ฟเวอร์อัตโนมัติ (นาฬิกา, คั่นด้วยลูกน้ำ)
# ตัวอย่าง: 4,10,16,22 = รีสตาร์ทที่ 04:00, 10:00, 16:00, 22:00
RESTART_SCHEDULE=4,10,16,22